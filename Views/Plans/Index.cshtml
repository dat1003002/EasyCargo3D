@model List<EasyCargo3D.Models.PlanEntity>
@{
    Layout = "_LayoutAdmin";
    ViewData["Title"] = "Kế hoạch xếp hàng";
    var executors = (List<EasyCargo3D.Models.AppUser>)ViewBag.Executors;
    bool canManage = ViewBag.CanManage; int meId = ViewBag.CurrentUserId;
    string Badge(string s) => s switch
    {
        "New" => "background:#2b3a55;color:#9ecbff;",
        "InProgress" => "background:#4a3b18;color:#f6ad55;",
        "Done" => "background:#1d3a26;color:#68d391;",
        _ => ""
    };
}
<div class="admin-page">
    <div><h2>📋 Kế hoạch xếp hàng</h2><a href="/">← Trang chính</a></div><br />
    <table>
        <thead><tr>
            <th>Tên KH</th><th>Xưởng</th><th>Container</th><th>Người tạo</th>
            <th>Người thực hiện</th><th>Trạng thái</th><th>Cập nhật</th><th style="width:120px;">Thao tác</th>
        </tr></thead>
        <tbody>
        @if (!Model.Any()) { <tr><td colspan="8" class="empty">Chưa có kế hoạch nào được lưu.</td></tr> }
        @foreach (var p in Model)
        {
            <tr>
                <td><b>@p.Name</b></td>
                <td>@(p.Workshop?.Name)</td>
                <td>@p.ContainerType</td>
                <td>@(p.CreatedBy?.FullName ?? p.CreatedBy?.Username)</td>
                <td>
                    @if (canManage)
                    {
                        <form method="post" action="/Plans/Assign" style="display:flex;gap:4px;">
                            @Html.AntiForgeryToken()<input type="hidden" name="id" value="@p.Id" />
                            <select name="assigneeId" onchange="this.form.submit()">
                                <option value="">— Chưa giao —</option>
                                @foreach (var e in executors) { <option value="@e.Id" selected="@(p.AssigneeId == e.Id)">@(string.IsNullOrEmpty(e.FullName) ? e.Username : e.FullName)</option> }
                            </select>
                        </form>
                    }
                    else { @(p.Assignee?.FullName ?? p.Assignee?.Username ?? "— Chưa giao —") }
                </td>
                <td><span class="badge" style="@Badge(p.Status)">@EasyCargo3D.Models.PlanStatus.Label(p.Status)</span></td>
                <td style="font-size:12px;color:#8aa0b8;">@p.UpdatedAt.ToString("dd/MM HH:mm")</td>
                <td>
                    @if (canManage || p.AssigneeId == meId)
                    {
                        <form method="post" action="/Plans/UpdateStatus" style="display:inline-block;margin-bottom:4px;">
                            @Html.AntiForgeryToken()<input type="hidden" name="id" value="@p.Id" />
                            <select name="status" onchange="this.form.submit()">
                                <option value="New" selected="@(p.Status == "New")">Mới tạo</option>
                                <option value="InProgress" selected="@(p.Status == "InProgress")">Đang thực hiện</option>
                                <option value="Done" selected="@(p.Status == "Done")">Hoàn thành</option>
                            </select>
                        </form>
                    }
                    @if (canManage)
                    {
                        <form method="post" action="/Plans/Delete" style="display:inline" onsubmit="return confirm('Xóa kế hoạch @p.Name?')">
                            @Html.AntiForgeryToken()<input type="hidden" name="id" value="@p.Id" />
                            <button class="btn b-del" type="submit">Xóa</button>
                        </form>
                    }
                </td>
            </tr>
        }
        </tbody>
    </table>
</div>
