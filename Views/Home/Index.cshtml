<script>
(function() {
    const leftPanel = document.getElementById('left-panel');

    function triggerResize() {
        if (window.resizeRenderer) window.resizeRenderer();
        setTimeout(() => { if (window.resizeRenderer) window.resizeRenderer(); }, 280);
    }

    function syncPanelToScreen() {
        // So sánh với document width thực tế, không dùng window.innerWidth (bị ảnh hưởng bởi zoom)
        const w = document.documentElement.clientWidth;
        const small = w <= 1100;
        const icon  = document.getElementById('left-toggle-icon');
        if (small && !leftPanel.classList.contains('collapsed')) {
            leftPanel.classList.add('collapsed');
            if (icon) icon.className = 'fas fa-chevron-right';
            triggerResize();
        } else if (!small && leftPanel.classList.contains('collapsed')) {
            leftPanel.classList.remove('collapsed');
            if (icon) icon.className = 'fas fa-chevron-left';
            triggerResize();
        }
    }

    syncPanelToScreen();
    let _resizeTimer;
    window.addEventListener('resize', () => {
        clearTimeout(_resizeTimer);
        _resizeTimer = setTimeout(syncPanelToScreen, 100);
    });
    window.addEventListener('orientationchange', () => setTimeout(syncPanelToScreen, 200));

    window.toggleLeftPanel = function() {
        const willCollapse = !leftPanel.classList.contains('collapsed');
        leftPanel.classList.toggle('collapsed', willCollapse);
        const icon = document.getElementById('left-toggle-icon');
        if (icon) icon.className = willCollapse ? 'fas fa-chevron-right' : 'fas fa-chevron-left';
        triggerResize();
    };

    window.toggleStatsPanel = function() {
        const sp = document.getElementById('stats-panel');
        if (!sp) return;
        const willCollapse = !sp.classList.contains('collapsed');
        sp.classList.toggle('collapsed', willCollapse);
        const icon = document.getElementById('stats-toggle-icon');
        if (icon) icon.className = willCollapse ? 'fas fa-chart-bar' : 'fas fa-chevron-right';
        triggerResize();
    };

    window.closeAllDrawers = function() {
        leftPanel.classList.add('collapsed');
        const icon = document.getElementById('left-toggle-icon');
        if (icon) icon.className = 'fas fa-chevron-right';
        if (window._closeFlyout) window._closeFlyout();
        triggerResize();
    };

    // Toàn màn hình cho khung 3D (CSS phủ kín — chạy cả trên iPad)
    function _setFsIcon(on) {
        const icon = document.querySelector('#btn-fullscreen i');
        if (icon) icon.className = on ? 'fas fa-compress' : 'fas fa-expand';
    }
    function _applyFs(on) {
        const el = document.getElementById('viewer-container');
        if (!el) return;
        el.classList.toggle('viewer-fs', on);
        document.body.classList.toggle('viewer-fs-on', on);
        _setFsIcon(on);
        triggerResize();
    }
    window.toggleFullscreen3D = function() {
        const root = document.documentElement;
        const goingOn = !document.getElementById('viewer-container').classList.contains('viewer-fs');
        _applyFs(goingOn);   // phủ kín bằng CSS (3D to, panel nổi lên trên)
        // Fullscreen API toàn TRANG để ẩn cả thanh trình duyệt
        try {
            if (goingOn) {
                const req = root.requestFullscreen || root.webkitRequestFullscreen;
                if (req) req.call(root).then(() => triggerResize()).catch(() => {});
            } else {
                const ex = document.exitFullscreen || document.webkitExitFullscreen;
                if ((document.fullscreenElement || document.webkitFullscreenElement) && ex) ex.call(document).catch(() => {});
            }
        } catch (e) {}
    };
    // Khi thoát fullscreen bằng Esc/F11 → bỏ luôn lớp phủ CSS
    function _onFsChange() {
        const fsEl = document.fullscreenElement || document.webkitFullscreenElement;
        if (!fsEl) _applyFs(false);
    }
    document.addEventListener('fullscreenchange', _onFsChange);
    document.addEventListener('webkitfullscreenchange', _onFsChange);
    document.addEventListener('keydown', e => {
        if (e.key === 'Escape' && document.getElementById('viewer-container').classList.contains('viewer-fs') && !document.fullscreenElement) {
            _applyFs(false);
        }
    });

})();
</script>

