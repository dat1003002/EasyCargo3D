@{
    ViewData["Title"] = "DRB - Container Load Planner";
    Layout = "~/Views/Shared/_LayoutCargo.cshtml";
}

<!-- NAVBAR -->
<nav class="navbar">
    <div class="logo">
        <img src="@Url.Content("~/images/logo.png")" alt="Logo" style="height:44px;width:auto;object-fit:contain;" />
    </div>
    <div class="nav-title">
        <div class="nav-title-text">HỆ THỐNG SẮP XẾP VỊ TRÍ CONTAINER</div>
    </div>
    <div class="nav-actions">
<button class="btn btn-outline" onclick="resetAll()"><i class="fas fa-redo"></i> Reset</button>
        <button class="btn btn-outline" id="btn-rotate" onclick="toggleAutoRotate()" title="Tự xoay 360°"><i class="fas fa-sync-alt"></i> Auto Rotate</button>
        <button class="btn btn-optimize" onclick="optimizePacking()"><i class="fas fa-magic"></i> Tối ưu</button>
        <button class="btn btn-success" onclick="calculatePacking()"><i class="fas fa-calculator"></i> Tính toán</button>
        <button class="btn btn-primary" onclick="exportPlan()"><i class="fas fa-file-export"></i> Export</button>
    </div>
</nav>

<!-- MAIN APP -->
<!-- Backdrop cho mobile drawer -->
<div class="drawer-backdrop" id="drawer-backdrop" onclick="closeAllDrawers()"></div>

<!-- Modal thư viện Pallet (chọn & quản lý) -->
<div class="ct-modal-overlay" id="pallet-library-modal" onclick="if(event.target===this)closePalletLibrary()">
    <div class="ct-modal" style="width:580px;">
        <div class="ct-modal-header">
            <span><i class="fas fa-database"></i> Thư viện Pallet</span>
            <div style="display:flex;gap:8px;align-items:center;">
                <button class="c-btn-edit" style="width:30px;height:30px;display:flex;align-items:center;justify-content:center;font-size:14px;border-radius:7px;" onclick="openAddPalletModal()" title="Thêm mới"><i class="fas fa-plus"></i></button>
                <button class="ct-modal-close" onclick="closePalletLibrary()"><i class="fas fa-times"></i></button>
            </div>
        </div>
        <div class="ct-modal-body" style="padding:12px;">
            <div id="pallet-library-list" style="display:flex;flex-direction:column;gap:6px;max-height:420px;overflow-y:auto;"></div>
        </div>
    </div>
</div>

<!-- Modal thêm/sửa Pallet Type -->
<div class="ct-modal-overlay" id="pallet-type-modal" onclick="if(event.target===this)closePalletModal()">
    <div class="ct-modal" style="width:480px;">
        <div class="ct-modal-header">
            <span id="pt-modal-title">Thêm Pallet</span>
            <button class="ct-modal-close" onclick="closePalletModal()"><i class="fas fa-times"></i></button>
        </div>
        <div class="ct-modal-body">
            <input type="hidden" id="pt-id" />
            <div class="ct-row">
                <div class="ct-field">
                    <label>Code <span class="req">*</span></label>
                    <input type="text" id="pt-code" class="input-dark" placeholder="vd: euro" maxlength="50" />
                </div>
                <div class="ct-field">
                    <label>Tên <span class="req">*</span></label>
                    <input type="text" id="pt-name" class="input-dark" placeholder="vd: Euro Pallet" maxlength="100" />
                </div>
            </div>
            <div class="ct-row">
                <div class="ct-field">
                    <label>Dài (cm)</label>
                    <input type="number" id="pt-length" class="input-dark" placeholder="120" min="1" />
                </div>
                <div class="ct-field">
                    <label>Rộng (cm)</label>
                    <input type="number" id="pt-width" class="input-dark" placeholder="80" min="1" />
                </div>
                <div class="ct-field">
                    <label>Cao (cm)</label>
                    <input type="number" id="pt-height" class="input-dark" placeholder="144" min="1" />
                </div>
            </div>
            <div class="ct-row">
                <div class="ct-field">
                    <label>Khối lượng (kg)</label>
                    <input type="number" id="pt-weight" class="input-dark" placeholder="500" min="0" />
                </div>
                <div class="ct-field">
                    <label>Màu sắc</label>
                    <input type="color" id="pt-color" class="input-dark" value="#F39C12" style="height:36px;padding:2px 4px;cursor:pointer;" />
                </div>
                <div class="ct-field">
                    <label>Thứ tự</label>
                    <input type="number" id="pt-sort" class="input-dark" placeholder="1" min="0" />
                </div>
            </div>
        </div>
        <div class="ct-modal-footer">
            <button class="btn-secondary" onclick="closePalletModal()">Hủy</button>
            <button class="btn-primary" onclick="savePalletModal()"><i class="fas fa-save"></i> Lưu</button>
        </div>
    </div>
</div>

<!-- Modal thêm/sửa Container Type -->
<div class="ct-modal-overlay" id="container-modal" onclick="if(event.target===this)closeContainerModal()">
    <div class="ct-modal">
        <div class="ct-modal-header">
            <span id="ct-modal-title">Thêm Container</span>
            <button class="ct-modal-close" onclick="closeContainerModal()"><i class="fas fa-times"></i></button>
        </div>
        <div class="ct-modal-body">
            <input type="hidden" id="ct-id" />
            <div class="ct-row">
                <div class="ct-field">
                    <label>Code <span class="req">*</span></label>
                    <input type="text" id="ct-code" class="input-dark" placeholder="vd: 20ft" maxlength="50" />
                </div>
                <div class="ct-field">
                    <label>Tên <span class="req">*</span></label>
                    <input type="text" id="ct-name" class="input-dark" placeholder="vd: 20ft Standard" maxlength="100" />
                </div>
            </div>
            <div class="ct-row">
                <div class="ct-field">
                    <label>Dài (cm)</label>
                    <input type="number" id="ct-length" class="input-dark" placeholder="585" min="1" />
                </div>
                <div class="ct-field">
                    <label>Rộng (cm)</label>
                    <input type="number" id="ct-width" class="input-dark" placeholder="235" min="1" />
                </div>
                <div class="ct-field">
                    <label>Cao (cm)</label>
                    <input type="number" id="ct-height" class="input-dark" placeholder="228" min="1" />
                </div>
            </div>
            <div class="ct-row">
                <div class="ct-field">
                    <label>Tải trọng tối đa (kg)</label>
                    <input type="number" id="ct-weight" class="input-dark" placeholder="28200" min="0" />
                </div>
                <div class="ct-field">
                    <label>Icon (HTML entity)</label>
                    <input type="text" id="ct-icon" class="input-dark" placeholder="&#x1F4E6;" />
                </div>
                <div class="ct-field">
                    <label>Thứ tự</label>
                    <input type="number" id="ct-sort" class="input-dark" placeholder="1" min="0" />
                </div>
            </div>
        </div>
        <div class="ct-modal-footer">
            <button class="btn-secondary" onclick="closeContainerModal()">Hủy</button>
            <button class="btn-primary" onclick="saveContainerModal()"><i class="fas fa-save"></i> Lưu</button>
        </div>
    </div>
</div>

<!-- Flyout panel khi sidebar thu nhỏ -->
<div class="sidebar-flyout" id="sidebar-flyout">
    <div class="flyout-title" id="flyout-title"></div>
    <div id="flyout-content"></div>
</div>

<div class="app-container">

    <!-- LEFT PANEL -->
    <div class="left-panel" id="left-panel">
        <div class="panel-tabs">
            <div class="tab active" onclick="switchTab('container')" title="Container"><i class="fas fa-box"></i><span class="tab-label">Container</span></div>
            <div class="tab" onclick="switchTab('import')" title="Import"><i class="fas fa-file-import"></i><span class="tab-label">Import</span></div>
            <div class="tab" onclick="switchTab('cargo')" title="Thêm"><i class="fas fa-plus"></i><span class="tab-label">Thêm</span></div>
            <div class="tab" onclick="switchTab('list')" title="Danh sách">
                <i class="fas fa-list"></i><span class="tab-label"> DS</span>
                <span id="item-count" class="tab-badge">0</span>
            </div>
            <div class="tab panel-collapse-btn" onclick="toggleLeftPanel()" id="left-toggle-btn" title="Thu/mở">
                <i class="fas fa-chevron-left" id="left-toggle-icon"></i>
            </div>
        </div>

        <!-- IMPORT TAB -->
        <div class="panel-content tab-pane" id="tab-import">
            <div class="import-header">
                <div class="section-title mb-0"><i class="fas fa-boxes"></i> Danh sách pallet</div>
                <div style="display:flex;gap:6px;">
                    <button class="btn btn-outline btn-sm" onclick="openPalletLibrary()" title="Chọn từ thư viện">
                        <i class="fas fa-database"></i> Thư viện
                    </button>
                    <button class="btn btn-outline btn-sm" onclick="addImportRow()" title="Thêm dòng">
                        <i class="fas fa-plus"></i>
                    </button>
                </div>
            </div>

            <div id="import-rows" class="import-rows-list"></div>

            <!-- Cài đặt multi-container -->
            <div class="import-settings-box">
                <div class="import-settings-title"><i class="fas fa-layer-group"></i> Cài đặt container</div>
                <div class="settings-grid">
                    <div>
                        <div class="dim-label">Loại container</div>
                        <select id="import-container-type" class="input-dark" onchange="onImportContainerChange()">
                            <!-- Được điền động từ API -->
                        </select>
                    </div>
                    <div>
                        <div class="dim-label">Số container</div>
                        <input type="number" id="import-container-count" value="8" min="1" max="50" class="input-dark input-bold">
                    </div>
                    <div class="span-full">
                        <div class="import-container-specs" id="import-container-specs" style="display:none;">
                            <span id="ics-dim"></span>
                            <span id="ics-vol"></span>
                            <span id="ics-wt"></span>
                        </div>
                    </div>
                    <div class="span-full">
                        <div class="dim-label">Tải trọng tối đa / container (kg)</div>
                        <input type="number" id="import-max-weight" value="19000" min="1000" step="500" class="input-dark input-bold input-accent">
                    </div>
                </div>
            </div>

            <div class="import-btn-row">
                <button class="add-btn add-btn-multi" onclick="importMultiContainer()">
                    <i class="fas fa-layer-group"></i> Tính theo số lượng
                </button>
                <button class="add-btn add-btn-auto" onclick="importAutoContainer()">
                    <i class="fas fa-magic"></i> Tự động tối ưu
                </button>
            </div>
            <div id="import-summary" class="import-summary" style="display:none;"></div>
        </div>

        <!-- CONTAINER TAB -->
        <div class="panel-content tab-pane active" id="tab-container">
            <div class="section-title"><i class="fas fa-ship"></i> Select Container Type</div>
            <div class="container-grid" id="container-grid"></div>

            <div class="section-title mt-16"><i class="fas fa-info-circle"></i> Container Specs</div>
            <div class="specs-box">
                <div id="spec-content"></div>
            </div>
        </div>

        <!-- CARGO TAB -->
        <div class="panel-content tab-pane" id="tab-cargo">
            <div class="section-title"><i class="fas fa-plus-circle"></i> Add Cargo Item</div>
            <div class="form-group">
                <label>Item Name</label>
                <input type="text" id="item-name" placeholder="e.g. Cardboard Box" />
            </div>
            <div class="form-group">
                <label>Dimensions (cm)</label>
                <div class="form-row">
                    <div><label>Length</label><input type="number" id="item-l" placeholder="100" min="1" /></div>
                    <div><label>Width</label><input type="number" id="item-w" placeholder="80" min="1" /></div>
                    <div><label>Height</label><input type="number" id="item-h" placeholder="60" min="1" /></div>
                </div>
            </div>
            <div class="form-row-2">
                <div class="form-group">
                    <label>Weight (kg)</label>
                    <input type="number" id="item-weight" placeholder="25" min="0" />
                </div>
                <div class="form-group">
                    <label>Quantity</label>
                    <input type="number" id="item-qty" value="1" min="1" max="999" />
                </div>
            </div>
            <div class="form-group">
                <label>Color</label>
                <div class="color-row" id="color-picker">
                    <div class="color-dot active" style="background:#E74C3C" data-color="#E74C3C"></div>
                    <div class="color-dot" style="background:#3498DB" data-color="#3498DB"></div>
                    <div class="color-dot" style="background:#2ECC71" data-color="#2ECC71"></div>
                    <div class="color-dot" style="background:#F39C12" data-color="#F39C12"></div>
                    <div class="color-dot" style="background:#9B59B6" data-color="#9B59B6"></div>
                    <div class="color-dot" style="background:#1ABC9C" data-color="#1ABC9C"></div>
                    <div class="color-dot" style="background:#E67E22" data-color="#E67E22"></div>
                    <div class="color-dot" style="background:#34495E" data-color="#34495E"></div>
                    <div class="color-dot" style="background:#E91E63" data-color="#E91E63"></div>
                    <div class="color-dot" style="background:#00BCD4" data-color="#00BCD4"></div>
                </div>
            </div>
            <div class="form-group">
                <label>Description (optional)</label>
                <input type="text" id="item-desc" placeholder="Notes..." />
            </div>
            <button class="add-btn" onclick="addCargoItem()"><i class="fas fa-plus"></i> Add to Load</button>

            <div class="section-title mt-20"><i class="fas fa-magic"></i> Quick Presets</div>
            <div class="preset-grid">
                <button class="btn btn-outline btn-preset" onclick="addPreset('pallet')">📦 Euro Pallet</button>
                <button class="btn btn-outline btn-preset" onclick="addPreset('drum')">🛢️ Drum 200L</button>
                <button class="btn btn-outline btn-preset" onclick="addPreset('box')">📫 Small Box</button>
                <button class="btn btn-outline btn-preset" onclick="addPreset('bag')">🎒 Big Bag</button>
            </div>
        </div>

        <!-- LIST TAB -->
        <div class="panel-content tab-pane" id="tab-list">
            <div class="list-header">
                <div class="section-title mb-0"><i class="fas fa-list-ul"></i> Cargo List</div>
                <button class="btn btn-danger" onclick="clearAll()">Clear All</button>
            </div>
            <div class="cargo-list" id="cargo-list">
                <div class="empty-state">
                    <i class="fas fa-inbox"></i>
                    <p>No items yet.<br>Go to "Add Cargo" tab to add items.</p>
                </div>
            </div>
        </div>
    </div>

    <!-- 3D VIEWER -->
    <div class="viewer-container">

        <!-- MULTI-CONTAINER NAVIGATOR -->
        <div id="multi-nav" class="multi-nav">
            <div class="multi-nav-inner">
                <button onclick="navContainer(-1)" class="nav-ctrl-btn">&#8592;</button>
                <div id="multi-nav-label" class="multi-nav-label">Container 1 / 8</div>
                <button onclick="navContainer(1)" class="nav-ctrl-btn">&#8594;</button>
                <div id="multi-nav-tabs" class="multi-nav-tabs"></div>
                <div class="multi-nav-actions">
                    <div id="multi-nav-info" class="multi-nav-info"></div>
                    <button onclick="toggleOverviewMode()" id="btn-overview" class="nav-action-btn nav-action-primary">
                        <i class="fas fa-th"></i> Tổng quan
                    </button>
                    <button onclick="toggleDetailPanel()" id="btn-detail" class="nav-action-btn">
                        <i class="fas fa-table"></i> Chi tiết
                    </button>
                </div>
            </div>
        </div>

        <!-- OVERVIEW GRID -->
        <div id="overview-grid" class="overview-grid" style="display:none;">
            <div class="overview-header">
                <span id="overview-title" class="overview-title-text"></span>
                <button class="nav-action-btn" onclick="toggleOverviewMode()" style="margin-left:auto;">
                    <i class="fas fa-times"></i> Đóng
                </button>
            </div>
            <div id="overview-cards" class="overview-cards"></div>
        </div>

        <!-- DETAIL TABLE PANEL -->
        <div id="detail-panel" class="detail-panel">
            <div id="detail-table-content"></div>
        </div>

        <canvas id="three-canvas"></canvas>

        <!-- TOOLBAR -->
        <div class="viewer-overlay">
            <button class="viewer-btn" onclick="resetCamera()" title="Reset View"><i class="fas fa-home"></i></button>
            <button class="viewer-btn" onclick="toggleWireframe()" title="Wireframe"><i class="fas fa-border-all"></i></button>
            <button class="viewer-btn" onclick="toggleLabels()" title="Labels"><i class="fas fa-tag"></i></button>
            <button class="viewer-btn" onclick="zoomIn()" title="Zoom In"><i class="fas fa-plus"></i></button>
            <button class="viewer-btn" onclick="zoomOut()" title="Zoom Out"><i class="fas fa-minus"></i></button>
        </div>

        <!-- VIEW BUTTONS -->
        <div class="view-controls">
            <button class="view-btn active" onclick="setView('perspective')">3D Perspective</button>
            <button class="view-btn" onclick="setView('front')">Front</button>
            <button class="view-btn" onclick="setView('top')">Top</button>
            <button class="view-btn" onclick="setView('side')">Side</button>
        </div>

        <!-- LOADING OVERLAY -->
        <div class="loading-overlay" id="loading">
            <div class="spinner"></div>
            <div class="loading-text">Calculating optimal loading plan...</div>
        </div>

        <!-- TOOLTIP -->
        <div class="tooltip-box" id="tooltip">
            <div class="tooltip-name" id="tooltip-name"></div>
            <div class="tooltip-info" id="tooltip-info"></div>
        </div>
    </div>

    <!-- STATS PANEL -->
    <div class="stats-panel" id="stats-panel" style="display:none">
        <div class="section-title"><i class="fas fa-chart-bar"></i> Statistics</div>

        <div class="stat-card">
            <div class="stat-label">Volume Utilization</div>
            <div><span class="stat-value" id="stat-vol">0</span><span class="stat-unit">%</span></div>
            <div class="progress-bar"><div class="progress-fill progress-vol" id="prog-vol" style="width:0%"></div></div>
        </div>

        <div class="stat-card">
            <div class="stat-label">Weight Utilization</div>
            <div><span class="stat-value" id="stat-wt">0</span><span class="stat-unit">%</span></div>
            <div class="progress-bar"><div class="progress-fill progress-wt" id="prog-wt" style="width:0%"></div></div>
        </div>

        <div class="stat-card">
            <div class="stat-label">Total Items Packed</div>
            <div><span class="stat-value" id="stat-items">0</span><span class="stat-unit"> pcs</span></div>
