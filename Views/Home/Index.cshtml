function addPalletToImport(id, btn) {
    const p = window._palletTypes.find(x => x.id === id);
    if (!p) return;
    const qtyInput = btn.closest('.pallet-lib-row').querySelector('.pallet-lib-qty');
    const qty = Math.max(1, parseInt(qtyInput?.value) || 1);
    addImportRow(p.name, p.length, p.width, p.height, p.weight, qty, p.color);
