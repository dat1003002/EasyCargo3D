    document.getElementById('pt-name').value   = '';
    document.getElementById('pt-length').value = '';
    document.getElementById('pt-width').value  = '';
    document.getElementById('pt-height').value = '';
    document.getElementById('pt-weight').value = '';
    document.getElementById('pt-color').value  = '#F39C12';
    document.getElementById('pt-sort').value   = window._palletTypes.length + 1;
    document.getElementById('pt-code').disabled = false;
    document.getElementById('pallet-type-modal').classList.add('show');
}

function openEditPalletModal(id) {
    const p = window._palletTypes.find(x => x.id === id);
    if (!p) return;
    document.getElementById('pt-modal-title').textContent = 'Sửa Pallet';
    document.getElementById('pt-id').value     = p.id;
    document.getElementById('pt-code').value   = p.code;
    document.getElementById('pt-name').value   = p.name;
    document.getElementById('pt-length').value = p.length;
    document.getElementById('pt-width').value  = p.width;
    document.getElementById('pt-height').value = p.height;
    document.getElementById('pt-weight').value = p.weight;
    document.getElementById('pt-color').value  = p.color;
    document.getElementById('pt-sort').value   = p.sortOrder;
    document.getElementById('pt-code').disabled = true;
    document.getElementById('pallet-type-modal').classList.add('show');
}

function closePalletModal() {
    document.getElementById('pallet-type-modal').classList.remove('show');
}

async function savePalletModal() {
    const id = parseInt(document.getElementById('pt-id').value) || 0;
    const payload = {
        id,
        code:      document.getElementById('pt-code').value.trim(),
        name:      document.getElementById('pt-name').value.trim(),
        length:    parseFloat(document.getElementById('pt-length').value) || 0,
        width:     parseFloat(document.getElementById('pt-width').value)  || 0,
        height:    parseFloat(document.getElementById('pt-height').value) || 0,
        weight:    parseFloat(document.getElementById('pt-weight').value) || 0,
        color:     document.getElementById('pt-color').value,
        sortOrder: parseInt(document.getElementById('pt-sort').value) || 0,
        isActive:  true
    };
    if (!payload.code || !payload.name) { alert('Vui lòng nhập Code và Tên.'); return; }
    const method = id ? 'PUT' : 'POST';
    const url    = id ? `/api/pallet-types/${id}` : '/api/pallet-types';
    try {
        const res = await fetch(url, { method, headers: { 'Content-Type': 'application/json' }, body: JSON.stringify(payload) });
        if (!res.ok) { alert('Lỗi lưu: ' + res.status); return; }
        closePalletModal();
        await loadPalletTypes();
        renderPalletLibrary();
    } catch (e) { alert('Lỗi kết nối: ' + e.message); }
}

async function deletePalletType(id) {
    const p = window._palletTypes.find(x => x.id === id);
    if (!p || !confirm(`Xóa pallet "${p.name}"?`)) return;
    try {
        const res = await fetch(`/api/pallet-types/${id}`, { method: 'DELETE' });
        if (!res.ok && res.status !== 204) { alert('Lỗi xóa: ' + res.status); return; }
        await loadPalletTypes();
        renderPalletLibrary();
    } catch (e) { alert('Lỗi kết nối: ' + e.message); }
}

// Flyout cho sidebar thu nhỏ — chạy sau cargo-planner.js
(function() {
    const leftPanel     = document.getElementById('left-panel');
    const flyout        = document.getElementById('sidebar-flyout');
    const flyoutTitle   = document.getElementById('flyout-title');
    const flyoutContent = document.getElementById('flyout-content');

    const TAB_LABELS = {
        container: 'Container',
        import:    'Nhập pallet',
        cargo:     'Thêm hàng',
        list:      'Danh sách'
    };

    function closeFlyout() {
        flyout.classList.remove('show');
    }
    window._closeFlyout = closeFlyout;

    function openFlyout(tabId) {
        const src = document.getElementById('tab-' + tabId);
        if (!src) return;
        flyoutTitle.textContent = TAB_LABELS[tabId] || tabId;
        flyoutContent.innerHTML = src.innerHTML;
        flyout.classList.add('show');
    }

    // Click ngoài flyout thì đóng
    document.addEventListener('click', function(e) {
        if (!flyout.contains(e.target) && !leftPanel.contains(e.target)) {
            closeFlyout();
        }
    });

    // Override switchTab (defined as global fn in cargo-planner.js)
    const _origSwitchTab = window.switchTab;
    window.switchTab = function(tabId) {
        if (leftPanel.classList.contains('collapsed')) {
            openFlyout(tabId);
        } else {
            closeFlyout();
            if (_origSwitchTab) _origSwitchTab(tabId);
        }
        if (tabId === 'list') loadPlansPanel('active', 'plans-active');
        if (tabId === 'cargo') loadPlansPanel('done', 'plans-done');
    };
})();

// ===== Hiển thị danh sách kế hoạch / lịch sử trong panel trái =====
function _statusBadge(s) {
    const m = { New: ['Mới', '#2b3a55', '#9ecbff'], InProgress: ['Đang làm', '#4a3b18', '#f6ad55'], Done: ['Hoàn thành', '#1d3a26', '#68d391'] };
    const x = m[s] || [s, '#333', '#ccc'];
    return `<span style="background:${x[1]};color:${x[2]};padding:1px 8px;border-radius:20px;font-size:11px;font-weight:700;">${x[0]}</span>`;
}
window._planCache = {};   // cache dữ liệu container theo planId
async function loadPlansPanel(scope, elId) {
    const box = document.getElementById(elId);
    if (!box) return;
    box.innerHTML = '<div class="empty-state"><p>Đang tải...</p></div>';
    try {
        const list = await (await fetch('/Plans/ListJson?scope=' + scope)).json();
        if (scope === 'active') { const b = document.getElementById('item-count'); if (b) b.textContent = list.length; }
        if (!list.length) { box.innerHTML = '<div class="empty-state"><i class="fas fa-inbox"></i><p>Chưa có kế hoạch.</p></div>'; return; }
        box.innerHTML = list.map(p => {
            const d = new Date(p.updatedAt);
            const dt = ('0'+d.getDate()).slice(-2)+'/'+('0'+(d.getMonth()+1)).slice(-2)+' '+('0'+d.getHours()).slice(-2)+':'+('0'+d.getMinutes()).slice(-2);
            return `<div style="background:#141b2d;border:1px solid #243049;border-radius:9px;margin-bottom:8px;overflow:hidden;">
                <div style="padding:10px 12px;cursor:pointer;" onclick="togglePlan(${p.id}, this)">
                    <div style="display:flex;justify-content:space-between;align-items:center;gap:6px;">
                        <b style="color:#e2e8f0;font-size:13px;"><i class="fas fa-caret-right plan-caret"></i> ${p.name}</b>${_statusBadge(p.status)}
                    </div>
                    <div style="font-size:11px;color:#8aa0b8;margin-top:5px;line-height:1.6;">
                        🏭 ${p.workshop || '—'} · 📦 ${p.containerType || '—'}<br>
                        👤 ${p.creator || '—'}${p.assignee ? ' · 🛠️ ' + p.assignee : ''} · 🕒 ${dt}
                    </div>
                </div>
                <div class="plan-children" data-pid="${p.id}" style="display:none;padding:0 10px 8px;"></div>
            </div>`;
        }).join('');
    } catch (e) {
        box.innerHTML = '<div class="empty-state"><p>Lỗi tải danh sách.</p></div>';
    }
}

async function togglePlan(id, headerEl) {
    const child = headerEl.parentElement.querySelector('.plan-children');
    const caret = headerEl.querySelector('.plan-caret');
    if (child.style.display !== 'none') { child.style.display = 'none'; if(caret) caret.className='fas fa-caret-right plan-caret'; return; }
    if(caret) caret.className='fas fa-caret-down plan-caret';
    child.style.display = 'block';
    await renderPlanContainers(id, child);
}

async function renderPlanContainers(id, child) {
    child.innerHTML = '<div style="color:#8aa0b8;font-size:11px;padding:6px;">Đang tải...</div>';
    try {
        if (!window._planCache[id]) {
            let data = await (await fetch('/Plans/Data?id=' + id)).json();
            if (!Array.isArray(data)) data = data ? [data] : [];
            window._planCache[id] = data;
        }
        const meta = await (await fetch('/Plans/Containers?id=' + id)).json();
        const data = window._planCache[id];
        const items = meta.items || [];
        if (!data.length) { child.innerHTML = '<div style="color:#8aa0b8;font-size:11px;padding:6px;">Không có container.</div>'; return; }
        const anyDoing = items.some(x => x && x.doing);
        window._photoStore = window._photoStore || {};
        child.innerHTML = data.map((pl, i) => {
            window._photoStore[id + '_' + i] = (items[i] && items[i].photos) || [];
            const c = pl.container || {};
            const cnt = (pl.packedItems || []).filter(x => !(x.item && x.item.isWood)).length;
            const info = items[i] || { name: 'Container ' + (i+1), done: false, doing: false };
            let action = '';
            if (info.done) action = `<span style="color:#68d391;font-size:11px;font-weight:700;">✅ Đã xếp</span>`;
            else if (info.doing) action = `<span style="color:#f6ad55;font-size:11px;font-weight:700;">⏳ Đang thực hiện</span><div style="color:#718096;font-size:10px;">(xác nhận từng pallet trên màn hình 3D)</div>`;
            else if (meta.canExecute && !anyDoing) action = `<button onclick="event.stopPropagation();startContainer(${id},${i},'${(info.name||'').replace(/'/g,'')}')" style="background:#ed8936;border:none;color:#fff;border-radius:6px;padding:4px 8px;font-size:11px;cursor:pointer;">▶ Xác nhận làm</button>`;
            else if (meta.canExecute) action = `<span style="color:#718096;font-size:11px;">🔒 Chờ hoàn thành container đang làm</span>`;
            const rename = meta.canRename ? `<i class="fas fa-pen" title="Đổi tên" style="color:#63b3ed;cursor:pointer;margin-left:6px;" onclick="event.stopPropagation();renameContainer(${id},${i},'${(info.name||'').replace(/'/g,'')}')"></i>` : '';
            return `<div style="background:#11192b;border:1px solid #2d3f5e;border-radius:7px;padding:7px 10px;margin-top:5px;">
                <div style="display:flex;justify-content:space-between;align-items:center;gap:6px;">
                    <div style="font-size:12px;cursor:pointer;" onclick="${info.doing ? `resumeContainer(${id},${i})` : (info.done ? `playCompletionReplay(${id},${i})` : `openSavedContainer(${id},${i},false)`)}">
                        <b style="color:#9ecbff;">📦 ${info.name}</b>${rename}
                        <div style="color:#8aa0b8;font-size:11px;">${c.name || ''} · ${cnt} pallet · ${Math.round(pl.totalWeight||0).toLocaleString('vi-VN')} kg · mở 3D ›</div>
                        ${(info.photos && info.photos.length) ? `<div style="margin-top:3px;"><span onclick="event.stopPropagation();openPhotosKey('${id}_${i}')" style="color:#68d391;cursor:pointer;font-size:11px;"><i class="fas fa-images"></i> Xem ${info.photos.length} ảnh đã chụp</span></div>` : ''}
                    </div>
                    <div style="white-space:nowrap;">${action}</div>
                </div>
            </div>`;
        }).join('');
    } catch (e) { child.innerHTML = '<div style="color:#fc8181;font-size:11px;">Lỗi tải dữ liệu.</div>'; }
}

// Phát lại mô phỏng container ĐÃ HOÀN THÀNH: xếp pallet → néo dây → đóng cửa → thông báo
function playCompletionReplay(id, idx) {
    openSavedContainer(id, idx);                 // dựng cảnh (cửa mở, chưa néo)
    try { autoRotate = true; } catch (e) {}
    showForkliftWatchBanner(true, '🎬 Mô phỏng xếp container...');
    setTimeout(() => { if (typeof addLashing === 'function') try { addLashing(); } catch (e) {} }, 350);
    window._onForkliftDone = function() {
        try { autoRotate = false; } catch (e) {}
        try { if (typeof addLashing === 'function') addLashing(); } catch (e) {}  // néo dây đầy đủ (cả đuôi)
        try { doorsClosed = true; applyDoorState(); } catch (e) {}                // đóng cửa + niêm phong
        showForkliftWatchBanner(false);
        showToast('✅ Hoàn thành xếp container', true);
    };
    setTimeout(() => { if (typeof playForkliftSim === 'function') playForkliftSim(); }, 700);
}

function openSavedContainer(id, idx, closed) {
    const data = window._planCache[id];
    if (!data || !data.length) return;
    multiPlans = data;
    multiCurrentIdx = idx;
    const nav = document.getElementById('multi-nav');
    if (nav) nav.style.display = 'flex';
    navContainer(idx, true);
    // Container đã hoàn thành → hiển thị ĐÓNG CỬA + niêm phong + DÂY NEO
    if (closed) {
        try { doorsClosed = true; applyDoorState(); } catch (e) {}
        setTimeout(() => { if (typeof addLashing === 'function') try { addLashing(); } catch (e) {} }, 350);
    }
}

async function renameContainer(id, idx, oldName) {
    const name = prompt('Đổi tên container:', oldName);
    if (name == null || !name.trim()) return;
    const fd = new URLSearchParams({ id, idx, name: name.trim() });
    await fetch('/Plans/RenameContainer', { method:'POST', headers:{'Content-Type':'application/x-www-form-urlencoded'}, body: fd });
    // tải lại danh sách
    document.querySelectorAll(`.plan-children[data-pid="${id}"]`).forEach(c => renderPlanContainers(id, c));
}

// ===== XEM ẢNH ĐÃ CHỤP =====
