<script>
// ===== Danh sách loại container theo ƯU TIÊN (thêm bao nhiêu loại tùy ý) =====
window._ctypeList = [];   // các loại THÊM sau loại chính
function addCtype() {
    const pick = document.getElementById('ctype-pick');
    const key  = pick && pick.value;
    if (!key || !CONTAINERS[key]) return;
    const mainKey = document.getElementById('import-container-type')?.value;
    if (key === mainKey) { alert('Loại này đã là container chính (ưu tiên 1).'); return; }
    if (window._ctypeList.includes(key)) { alert('Đã có loại này trong danh sách.'); return; }
    window._ctypeList.push(key);
    renderCtypeList();
}
function removeCtype(key) {
    window._ctypeList = window._ctypeList.filter(k => k !== key);
    renderCtypeList();
}
function renderCtypeList() {
    const box = document.getElementById('ctype-list');
    if (!box) return;
    window._ctypeWeights = window._ctypeWeights || {};
    const wInput = (type) => {
        const v = window._ctypeWeights[type] || '';
        return `<input type="number" min="0" value="${v}" placeholder="Tải trọng tối đa (kg)" oninput="window._ctypeWeights['${type}']=this.value"
            style="width:140px;padding:4px 8px;background:#11192b;border:1px solid #36507a;border-radius:6px;color:#68d391;font-size:12px;font-weight:700;">`;
    };
    const mainKey = document.getElementById('import-container-type')?.value;
    const mc = mainKey && CONTAINERS[mainKey] ? CONTAINERS[mainKey] : null;
    let html = `<div style="display:flex;align-items:center;gap:6px;background:#1a2740;border:1px solid #2d4468;border-radius:7px;padding:5px 9px;font-size:12px;">
        <span style="background:#3f8fcc;color:#fff;border-radius:4px;padding:1px 6px;font-weight:700;">1</span>
        <b style="color:#9ecbff;flex:1;">${mc ? mc.name : '(chưa chọn)'}</b>
        ${mainKey ? wInput(mainKey) : ''}</div>`;
    window._ctypeList.forEach((k, i) => {
        const c = CONTAINERS[k];
        html += `<div style="display:flex;align-items:center;gap:6px;background:#16213a;border:1px solid #2d3f5e;border-radius:7px;padding:5px 9px;font-size:12px;">
            <span style="background:#4a5568;color:#fff;border-radius:4px;padding:1px 6px;font-weight:700;">${i + 2}</span>
            <b style="color:#cbd5e0;flex:1;">${c ? c.name : k}</b>
            ${wInput(k)}
            <span style="color:#fc8181;cursor:pointer;font-weight:700;" onclick="removeCtype('${k}')">✕</span></div>`;
    });
    box.innerHTML = html;
}
function collectContainerTypes() {
    const mainKey = document.getElementById('import-container-type')?.value;
    const list = [];
    if (mainKey && CONTAINERS[mainKey]) list.push(mainKey);
    (window._ctypeList || []).forEach(k => { if (CONTAINERS[k] && !list.includes(k)) list.push(k); });
    return list;
}
// Danh sách {type, maxWeight} theo ưu tiên — tải trọng người dùng nhập riêng
function collectContainers() {
    window._ctypeWeights = window._ctypeWeights || {};
    return collectContainerTypes().map(t => ({ type: t, maxWeight: parseFloat(window._ctypeWeights[t]) || 0 }));
}

// ===== MENU TÀI KHOẢN =====
function toggleUserMenu(e) {
    if (e) e.stopPropagation();
    const m = document.getElementById('user-menu');
    if (m) m.style.display = (m.style.display === 'block') ? 'none' : 'block';
}
document.addEventListener('click', function(){ const m=document.getElementById('user-menu'); if(m) m.style.display='none'; });
// Tải số kế hoạch cho badge ngay khi mở trang
window.addEventListener('load', function(){ setTimeout(function(){ try{ loadPlansPanel('active','plans-active'); }catch(e){} }, 300); });

// ===== LƯU KẾ HOẠCH (giao người thực hiện) =====
async function openSavePlan() {
    const hasPlan = (typeof multiPlans !== 'undefined' && multiPlans && multiPlans.length) ||
                    (typeof currentPlan !== 'undefined' && currentPlan);
    if (!hasPlan) { alert('Chưa có kế hoạch! Hãy "Tự động tối ưu" hoặc "Tính theo số lượng" trước.'); return; }
    try {
        const meta = await (await fetch('/Plans/SaveMeta')).json();
        const ws = document.getElementById('sp-workshop');
        ws.innerHTML = (meta.workshops || []).map(w => `<option value="${w.id}">${w.name}</option>`).join('');
        const as = document.getElementById('sp-assignee');
        as.innerHTML = '<option value="">— Chưa giao —</option>' +
            (meta.executors || []).map(e => `<option value="${e.id}">${e.name}</option>`).join('');
        if (!meta.workshops || !meta.workshops.length) { alert('Bạn chưa được gán xưởng nào. Liên hệ admin.'); return; }
        document.getElementById('saveplan-overlay').style.display = 'flex';
    } catch (e) { alert('Không tải được dữ liệu lưu kế hoạch.'); }
}
function closeSavePlan() { document.getElementById('saveplan-overlay').style.display = 'none'; }
async function submitSavePlan() {
    const name = document.getElementById('sp-name').value.trim();
    if (!name) { alert('Nhập tên kế hoạch.'); return; }
    const workshopId = parseInt(document.getElementById('sp-workshop').value) || 0;
    const assigneeVal = document.getElementById('sp-assignee').value;
    const assigneeId = assigneeVal ? parseInt(assigneeVal) : null;
    const planData = (typeof multiPlans !== 'undefined' && multiPlans && multiPlans.length)
        ? multiPlans : (typeof currentPlan !== 'undefined' ? currentPlan : null);
    const containerType = document.getElementById('import-container-type')?.value || '';
    try {
        const res = await fetch('/Plans/Save', {
            method: 'POST', headers: { 'Content-Type': 'application/json' },
            body: JSON.stringify({ name, containerType, workshopId, assigneeId, dataJson: JSON.stringify(planData) })
        });
        if (res.ok) { closeSavePlan(); alert('✅ Đã lưu kế hoạch!'); }
        else { alert('Lưu thất bại: ' + (await res.text())); }
    } catch (e) { alert('Lỗi khi lưu kế hoạch.'); }
}

// Cập nhật specs khi chọn container type trong tab Import
