@{
    ViewData["Title"] = "DRB - Container Load Planner";
    Layout = "~/Views/Shared/_LayoutCargo.cshtml";
}

<!-- NAVBAR -->
<nav class="navbar">
    <div class="logo">
        <img src="@Url.Content("~/images/logo.png")" alt="Logo" style="height:44px;width:auto;max-width:180px;object-fit:contain;display:block;" />
    </div>
    <div class="nav-title">
        <div class="nav-title-text">HỆ THỐNG SẮP XẾP VỊ TRÍ CONTAINER</div>
    </div>
    <div class="nav-actions">
        @{ var isAdmin = User.IsInRole("Admin"); var canManage = isAdmin || User.IsInRole("Manager");
           var fullName = User.FindFirst("FullName")?.Value ?? User.Identity?.Name; }
        <button class="btn btn-primary" onclick="exportPlan()"><i class="fas fa-file-export"></i> Export</button>

        <!-- Menu tài khoản: bấm vào tên để xổ ra -->
        <div style="position:relative;display:inline-block;margin-left:6px;">
            <span onclick="toggleUserMenu(event)" style="cursor:pointer;display:inline-flex;align-items:center;gap:8px;padding:5px 12px;background:rgba(255,255,255,0.07);border-radius:20px;font-size:13px;color:#cbd5e0;">
                <i class="fas fa-user-circle"></i> @fullName <i class="fas fa-caret-down"></i>
            </span>
            <div id="user-menu" style="display:none;position:absolute;right:0;top:115%;min-width:190px;background:#141b2d;border:1px solid #2d3f5e;border-radius:10px;box-shadow:0 8px 30px rgba(0,0,0,0.6);z-index:300;overflow:hidden;">
                <a href="/Plans" class="usermenu-item"><i class="fas fa-list"></i> Kế hoạch</a>
                @if(isAdmin){
                <a href="/Users" class="usermenu-item"><i class="fas fa-users"></i> Người dùng</a>
                <a href="/Workshops" class="usermenu-item"><i class="fas fa-industry"></i> Xưởng</a>
                }
                <a href="/Account/Logout" class="usermenu-item" style="color:#fc8181;border-top:1px solid #243049;"><i class="fas fa-sign-out-alt"></i> Đăng xuất</a>
            </div>
        </div>
    </div>
</nav>
<style>
    .usermenu-item{display:flex;align-items:center;gap:9px;padding:10px 14px;color:#e2e8f0;text-decoration:none;font-size:13px;}
    .usermenu-item:hover{background:#1b2740;}
    .usermenu-item i{width:16px;text-align:center;color:#9ecbff;}
    .usermenu-item[style*="fc8181"] i{color:#fc8181;}
</style>

<!-- HỘP THOẠI LƯU KẾ HOẠCH -->
<div id="saveplan-overlay" style="display:none;position:fixed;inset:0;background:rgba(0,0,0,0.6);z-index:200;align-items:center;justify-content:center;" onclick="if(event.target===this)closeSavePlan()">
  <div style="width:380px;background:#141b2d;border:1px solid #2d3f5e;border-radius:12px;padding:20px;color:#e2e8f0;">
    <h3 style="margin-bottom:14px;">💾 Lưu kế hoạch xếp hàng</h3>
    <label style="font-size:12px;color:#9ecbff;">Tên kế hoạch</label>
    <input id="sp-name" style="width:100%;padding:8px 10px;margin:5px 0 12px;background:#11192b;border:1px solid #36507a;border-radius:7px;color:#fff;" placeholder="VD: KH xuất hàng 15/06" />
    <label style="font-size:12px;color:#9ecbff;">Xưởng</label>
    <select id="sp-workshop" style="width:100%;padding:8px 10px;margin:5px 0 12px;background:#11192b;border:1px solid #36507a;border-radius:7px;color:#fff;"></select>
    <label style="font-size:12px;color:#9ecbff;">Người thực hiện</label>
    <select id="sp-assignee" style="width:100%;padding:8px 10px;margin:5px 0 16px;background:#11192b;border:1px solid #36507a;border-radius:7px;color:#fff;"><option value="">— Chưa giao —</option></select>
    <div style="display:flex;gap:8px;">
      <button class="btn btn-success" style="flex:1;" onclick="submitSavePlan()">Lưu</button>
      <button class="btn btn-outline" style="flex:1;" onclick="closeSavePlan()">Hủy</button>
    </div>
  </div>
</div>
<div class="drawer-backdrop" id="drawer-backdrop" onclick="closeAllDrawers()"></div>

<!-- LIGHTBOX: phóng to 1 ảnh ngay trên trang -->
<div id="lightbox-overlay" style="display:none;position:fixed;inset:0;background:rgba(0,0,0,0.95);z-index:440;align-items:center;justify-content:center;cursor:zoom-out;" onclick="closeLightbox()">
    <img id="lightbox-img" src="" style="max-width:94vw;max-height:92vh;object-fit:contain;border-radius:8px;box-shadow:0 10px 50px rgba(0,0,0,0.7);" />
    <button onclick="event.stopPropagation();closeLightbox()" style="position:absolute;top:18px;right:24px;background:rgba(255,255,255,0.12);border:none;color:#fff;font-size:28px;width:46px;height:46px;border-radius:50%;cursor:pointer;">&times;</button>
</div>

<!-- MODAL XEM ẢNH ĐÃ CHỤP -->
<div id="photos-overlay" style="display:none;position:fixed;inset:0;background:rgba(8,11,18,0.92);z-index:420;align-items:center;justify-content:center;backdrop-filter:blur(4px);" onclick="if(event.target===this)closePhotos()">
    <div style="width:min(900px,92vw);max-height:88vh;background:#141b2d;border:1px solid #2d3f5e;border-radius:14px;display:flex;flex-direction:column;box-shadow:0 20px 60px rgba(0,0,0,0.6);overflow:hidden;">
        <div style="display:flex;align-items:center;justify-content:space-between;padding:14px 18px;border-bottom:1px solid #243049;">
            <div style="font-weight:700;color:#e2e8f0;font-size:15px;"><i class="fas fa-images" style="color:#68d391;"></i> <span id="photos-title">Ảnh thực tế đã chụp</span></div>
            <button onclick="closePhotos()" style="background:none;border:none;color:#8aa0b8;font-size:24px;line-height:1;cursor:pointer;">&times;</button>
        </div>
        <div id="photos-grid" style="padding:16px;display:grid;grid-template-columns:repeat(auto-fill,minmax(150px,1fr));gap:12px;overflow:auto;"></div>
    </div>
</div>

<!-- MODAL CAMERA: xác minh OCR + lưu ảnh container -->
<div id="camera-overlay" style="display:none;position:fixed;inset:0;background:rgba(0,0,0,0.88);z-index:400;flex-direction:column;align-items:center;justify-content:center;gap:12px;padding:16px;">
    <div id="camera-title" style="color:#fff;font-weight:700;font-size:16px;text-align:center;"></div>
    <video id="camera-video" autoplay playsinline muted style="max-width:92vw;max-height:55vh;border-radius:10px;background:#000;"></video>
    <!-- Khung chọn vùng chữ (verify, sau khi chụp) -->
    <div id="verify-pane" style="display:none;flex-direction:column;align-items:center;gap:8px;">
        <div style="color:#9ecbff;font-size:12px;text-align:center;">Kéo khoanh vùng chữ cần phân tích (để trống = cả ảnh). Chữ ngang/dọc/mờ đều nhận diện.</div>
        <canvas id="verify-canvas" style="max-width:92vw;max-height:50vh;border-radius:8px;border:1px solid #36507a;touch-action:none;cursor:crosshair;"></canvas>
        <div style="display:flex;gap:10px;flex-wrap:wrap;justify-content:center;">
            <button onclick="analyzeVerify()" class="btn btn-success"><i class="fas fa-magnifying-glass"></i> Phân tích</button>
            <button onclick="retakeVerify()" class="btn btn-outline"><i class="fas fa-rotate-left"></i> Chụp lại</button>
            <button onclick="closeCamera()" class="btn btn-outline">Hủy</button>
        </div>
    </div>
    <div id="camera-status" style="color:#f6ad55;font-size:13px;min-height:18px;text-align:center;max-width:92vw;"></div>
    <div id="camera-thumbs" style="display:flex;gap:6px;flex-wrap:wrap;max-width:92vw;justify-content:center;"></div>
    <div id="camera-actions" style="display:flex;gap:10px;flex-wrap:wrap;justify-content:center;">
        <button onclick="cameraCapture()" id="camera-capture-btn" class="btn btn-success"><i class="fas fa-camera"></i> Chụp</button>
        <button onclick="document.getElementById('camera-file').click()" id="camera-file-btn" class="btn btn-outline" style="display:none;"><i class="fas fa-image"></i> Ảnh có sẵn</button>
        <button onclick="cameraDone()" id="camera-done-btn" class="btn btn-primary" style="display:none;"><i class="fas fa-check"></i> Xong</button>
        <button onclick="closeCamera()" class="btn btn-outline">Hủy</button>
    </div>
    <input type="file" id="camera-file" accept="image/*" multiple style="display:none;" onchange="cameraPickFiles(this.files)" />
    <canvas id="camera-canvas" style="display:none;"></canvas>
</div>

<!-- Nút xác nhận đã xếp xong container (hiện sau khi xem mô phỏng) -->
<button id="finish-container-btn" style="display:none;position:fixed;bottom:80px;left:50%;transform:translateX(-50%);z-index:120;align-items:center;gap:8px;background:linear-gradient(135deg,#38a169,#2f855a);color:#fff;border:none;border-radius:25px;padding:12px 26px;font-size:15px;font-weight:700;cursor:pointer;box-shadow:0 6px 24px rgba(0,0,0,0.5);">
    <i class="fas fa-check-circle"></i> Đã xếp xong container này
</button>

<div class="ct-modal-overlay" id="pallet-library-modal" onclick="if(event.target===this)closePalletLibrary()">
    <div class="ct-modal" style="width:580px;">
        <div class="ct-modal-header">
            <span><i class="fas fa-database"></i> Thư viện Pallet</span>
            <div style="display:flex;gap:8px;align-items:center;">
                <button class="c-btn-edit" style="width:30px;height:30px;display:flex;align-items:center;justify-content:center;font-size:14px;border-radius:7px;" onclick="openAddPalletModal()" title="Thêm mới"><i class="fas fa-plus"></i></button>
                <button class="ct-modal-close" onclick="closePalletLibrary()"><i class="fas fa-times"></i></button>
            </div>
        </div>
        <div class="ct-modal-body" style="padding:12px;">
            <div id="pallet-library-list" style="display:flex;flex-direction:column;gap:6px;max-height:420px;overflow-y:auto;"></div>
        </div>
    </div>
</div>

<div class="ct-modal-overlay" id="pallet-type-modal" onclick="if(event.target===this)closePalletModal()">
    <div class="ct-modal" style="width:480px;">
        <div class="ct-modal-header">
            <span id="pt-modal-title">Thêm Pallet</span>
            <button class="ct-modal-close" onclick="closePalletModal()"><i class="fas fa-times"></i></button>
        </div>
        <div class="ct-modal-body">
            <input type="hidden" id="pt-id" />
            <div class="ct-row">
                <div class="ct-field">
                    <label>Code <span class="req">*</span></label>
                    <input type="text" id="pt-code" class="input-dark" placeholder="vd: euro" maxlength="50" />
                </div>
                <div class="ct-field">
                    <label>Tên <span class="req">*</span></label>
                    <input type="text" id="pt-name" class="input-dark" placeholder="vd: Euro Pallet" maxlength="100" />
                </div>
            </div>
            <div class="ct-row">
                <div class="ct-field">
                    <label>Dài (cm)</label>
                    <input type="number" id="pt-length" class="input-dark" placeholder="120" min="1" />
                </div>
                <div class="ct-field">
                    <label>Rộng (cm)</label>
                    <input type="number" id="pt-width" class="input-dark" placeholder="80" min="1" />
                </div>
                <div class="ct-field">
                    <label>Cao (cm)</label>
                    <input type="number" id="pt-height" class="input-dark" placeholder="144" min="1" />
                </div>
            </div>
            <div class="ct-row">
                <div class="ct-field">
                    <label>Khối lượng (kg)</label>
                    <input type="number" id="pt-weight" class="input-dark" placeholder="500" min="0" />
                </div>
                <div class="ct-field">
                    <label>Màu sắc</label>
                    <input type="color" id="pt-color" class="input-dark" value="#F39C12" style="height:36px;padding:2px 4px;cursor:pointer;" />
                </div>
                <div class="ct-field">
                    <label>Thứ tự</label>
                    <input type="number" id="pt-sort" class="input-dark" placeholder="1" min="0" />
                </div>
            </div>
        </div>
        <div class="ct-modal-footer">
            <button class="btn-secondary" onclick="closePalletModal()">Hủy</button>
            <button class="btn-primary" onclick="savePalletModal()"><i class="fas fa-save"></i> Lưu</button>
        </div>
    </div>
</div>

<div class="ct-modal-overlay" id="container-modal" onclick="if(event.target===this)closeContainerModal()">
    <div class="ct-modal">
        <div class="ct-modal-header">
            <span id="ct-modal-title">Thêm Container</span>
            <button class="ct-modal-close" onclick="closeContainerModal()"><i class="fas fa-times"></i></button>
        </div>
        <div class="ct-modal-body">
            <input type="hidden" id="ct-id" />
            <div class="ct-row">
                <div class="ct-field">
                    <label>Code <span class="req">*</span></label>
                    <input type="text" id="ct-code" class="input-dark" placeholder="vd: 20ft" maxlength="50" />
                </div>
                <div class="ct-field">
                    <label>Tên <span class="req">*</span></label>
                    <input type="text" id="ct-name" class="input-dark" placeholder="vd: 20ft Standard" maxlength="100" />
                </div>
            </div>
            <div class="ct-row">
                <div class="ct-field">
                    <label>Dài (cm)</label>
                    <input type="number" id="ct-length" class="input-dark" placeholder="585" min="1" />
                </div>
                <div class="ct-field">
                    <label>Rộng (cm)</label>
                    <input type="number" id="ct-width" class="input-dark" placeholder="235" min="1" />
                </div>
                <div class="ct-field">
                    <label>Cao (cm)</label>
                    <input type="number" id="ct-height" class="input-dark" placeholder="228" min="1" />
                </div>
            </div>
            <div class="ct-row">
                <div class="ct-field">
                    <label>Tải trọng tối đa (kg)</label>
                    <input type="number" id="ct-weight" class="input-dark" placeholder="28200" min="0" />
                </div>
                <div class="ct-field">
                    <label>Icon (HTML entity)</label>
                    <input type="text" id="ct-icon" class="input-dark" placeholder="&#x1F4E6;" />
                </div>
                <div class="ct-field">
                    <label>Thứ tự</label>
                    <input type="number" id="ct-sort" class="input-dark" placeholder="1" min="0" />
                </div>
            </div>
        </div>
        <div class="ct-modal-footer">
            <button class="btn-secondary" onclick="closeContainerModal()">Hủy</button>
            <button class="btn-primary" onclick="saveContainerModal()"><i class="fas fa-save"></i> Lưu</button>
        </div>
    </div>
</div>

<!-- Flyout panel khi sidebar thu nhỏ -->
<div class="sidebar-flyout" id="sidebar-flyout">
    <div style="display:flex;align-items:center;justify-content:space-between;gap:8px;">
        <div class="flyout-title" id="flyout-title" style="flex:1;"></div>
        <button type="button" onclick="window._closeFlyout && window._closeFlyout()" title="Thu nhỏ"
            style="background:#2d3f5e;border:none;color:#fff;width:34px;height:34px;border-radius:8px;font-size:18px;cursor:pointer;flex:none;">&times;</button>
    </div>
    <div id="flyout-content"></div>
</div>

<div class="app-container">

    <!-- LEFT PANEL -->
    <div class="left-panel" id="left-panel">
        <div class="panel-tabs">
            <div class="tab active" onclick="switchTab('container')" title="Container"><i class="fas fa-box"></i><span class="tab-label">Container</span></div>
            @if(canManage){
            <div class="tab" onclick="switchTab('import')" title="Import"><i class="fas fa-file-import"></i><span class="tab-label">Import</span></div>
            }
            <div class="tab" onclick="switchTab('list')" title="Kế hoạch">
                <i class="fas fa-list"></i><span class="tab-label"> Kế hoạch</span>
                <span id="item-count" class="tab-badge">0</span>
            </div>
            <div class="tab" onclick="switchTab('cargo')" title="Lịch sử"><i class="fas fa-clock-rotate-left"></i><span class="tab-label">Lịch sử</span></div>
            <div class="tab panel-collapse-btn" onclick="toggleLeftPanel()" id="left-toggle-btn" title="Thu/mở">
                <i class="fas fa-chevron-left" id="left-toggle-icon"></i>
            </div>
        </div>

        <!-- IMPORT TAB -->
        <div class="panel-content tab-pane" id="tab-import">
            <div class="import-header">
                <div class="section-title mb-0"><i class="fas fa-boxes"></i> Danh sách pallet</div>
                <div style="display:flex;gap:6px;">
                    <button class="btn btn-outline btn-sm" onclick="openPalletLibrary()" title="Chọn từ thư viện">
                        <i class="fas fa-database"></i> Thư viện
                    </button>
                    <button class="btn btn-outline btn-sm" onclick="addImportRow()" title="Thêm dòng">
                        <i class="fas fa-plus"></i>
                    </button>
                </div>
            </div>

            <div id="import-rows" class="import-rows-list"></div>

            <!-- Cài đặt multi-container -->
            <div class="import-settings-box">
                <div class="import-settings-title"><i class="fas fa-layer-group"></i> Cài đặt container</div>
                <div class="settings-grid">
                    <div class="span-full" style="display:flex;gap:10px;align-items:flex-end;">
                        <div style="flex:1;min-width:0;">
                            <div class="dim-label">Loại container chính (ưu tiên)</div>
                            <select id="import-container-type" class="input-dark" style="width:100%;" onchange="onImportContainerChange()">
                                <!-- Được điền động từ API -->
                            </select>
                        </div>
                        <div style="width:84px;flex:none;">
                            <div class="dim-label">Số container</div>
                            <input type="number" id="import-container-count" value="8" min="1" max="50" class="input-dark input-bold" style="width:100%;">
                        </div>
                    </div>
                    <div class="span-full">
                        <div class="dim-label">Thêm loại container (theo thứ tự ưu tiên)</div>
                        <div style="display:flex;gap:6px;align-items:stretch;">
                            <select id="ctype-pick" class="input-dark" style="flex:1;min-width:0;"></select>
                            <button type="button" class="add-btn" style="background:#3f8fcc;white-space:nowrap;padding:6px 10px;font-size:12px;flex:none;width:30%;top:0;margin-top:0px;align-self:flex-start;" onclick="addCtype()">➕</button>
                        </div>
                        <div id="ctype-list" style="margin-top:6px;display:flex;flex-direction:column;gap:4px;"></div>
                    </div>

                    <div class="span-full">
                        <div class="import-container-specs" id="import-container-specs" style="display:none;">
                            <span id="ics-dim"></span>
                            <span id="ics-vol"></span>
                            <span id="ics-wt"></span>
                        </div>
                    </div>
                    <input type="hidden" id="import-max-weight" value="0" />
                    <div class="span-full" style="font-size:11px;color:#718096;">💡 Nhập tải trọng tối đa cho từng loại container ở danh sách phía trên.</div>
                </div>
            </div>

            <div class="import-btn-row">
                <button class="add-btn add-btn-multi" onclick="importMultiContainer()">
                    <i class="fas fa-layer-group"></i> Tính theo số lượng
                </button>
                <button class="add-btn add-btn-auto" onclick="importAutoContainer()">
                    <i class="fas fa-magic"></i> Tự động tối ưu
                </button>
            </div>
            <div class="import-btn-row" style="margin-top:8px;">
                <button class="add-btn" style="background:linear-gradient(135deg,#f6ad55,#ed8936);width:100%;" onclick="playForkliftSim()">
                    <i class="fas fa-truck-ramp-box"></i> Mô phỏng xe nâng xếp hàng
                </button>
            </div>
            @if(canManage){
            <div class="import-btn-row" style="margin-top:8px;">
                <button class="add-btn" style="background:linear-gradient(135deg,#38a169,#2f855a);width:100%;" onclick="openSavePlan()">
                    <i class="fas fa-save"></i> Lưu kế hoạch xếp container
                </button>
            </div>
            }
            <div id="import-summary" class="import-summary" style="display:none;"></div>
        </div>

        <!-- CONTAINER TAB -->
        <div class="panel-content tab-pane active" id="tab-container">
            <div class="section-title"><i class="fas fa-ship"></i> Select Container Type</div>
            <div class="container-grid" id="container-grid"></div>

            <div class="section-title mt-16"><i class="fas fa-info-circle"></i> Container Specs</div>
            <div class="specs-box">
                <div id="spec-content"></div>
            </div>
        </div>

        <!-- CARGO TAB -->
        <div class="panel-content tab-pane" id="tab-cargo">
            <div class="list-header">
                <div class="section-title mb-0"><i class="fas fa-clock-rotate-left"></i> Lịch sử (đã hoàn thành)</div>
                <button class="btn btn-outline" onclick="loadPlansPanel('done','plans-done')"><i class="fas fa-rotate"></i></button>
            </div>
            <div id="plans-done" class="cargo-list">
                <div class="empty-state"><i class="fas fa-inbox"></i><p>Đang tải...</p></div>
            </div>
        </div>

        <!-- LIST TAB -->
        <div class="panel-content tab-pane" id="tab-list">
            <div class="list-header">
                <div class="section-title mb-0"><i class="fas fa-list-ul"></i> Kế hoạch đã tạo</div>
                <button class="btn btn-outline" onclick="loadPlansPanel('active','plans-active')"><i class="fas fa-rotate"></i></button>
            </div>
            <div id="plans-active" class="cargo-list">
                <div class="empty-state"><i class="fas fa-inbox"></i><p>Đang tải...</p></div>
            </div>
        </div>
    </div>

    <!-- 3D VIEWER -->
    <div class="viewer-container" id="viewer-container">

        <!-- MULTI-CONTAINER NAVIGATOR -->
        <div id="multi-nav" class="multi-nav">
            <div class="multi-nav-inner">
                <button onclick="navContainer(-1)" class="nav-ctrl-btn">&#8592;</button>
                <div id="multi-nav-label" class="multi-nav-label">Container 1 / 8</div>
                <button onclick="navContainer(1)" class="nav-ctrl-btn">&#8594;</button>
                <div id="multi-nav-tabs" class="multi-nav-tabs"></div>
                <div class="multi-nav-actions">
                    <div id="multi-nav-info" class="multi-nav-info"></div>
                    <button onclick="toggleOverviewMode()" id="btn-overview" class="nav-action-btn nav-action-primary">
                        <i class="fas fa-th"></i> Tổng quan
                    </button>
                    <button onclick="toggleDetailPanel()" id="btn-detail" class="nav-action-btn">
                        <i class="fas fa-table"></i> Chi tiết
                    </button>
                </div>
            </div>
        </div>

        <!-- OVERVIEW GRID -->
