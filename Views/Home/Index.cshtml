            </button>
        </div>

        <div class="section-title mt-16"><i class="fas fa-palette"></i> Legend</div>
        <div id="legend" class="legend-list">
            <div class="stats-empty-state">
                <i class="fas fa-calculator"></i>
                <p>Bấm <strong>Tính toán</strong> để xem kết quả</p>
            </div>
        </div>

        <div id="optimize-result" class="optimize-result" style="display:none;">
            <div class="section-title optimize-title"><i class="fas fa-magic"></i> Số lượng tối ưu</div>
            <div id="optimize-list" class="optimize-list"></div>
        </div>
    </div>
</div>

<script>
(function() {
    const leftPanel = document.getElementById('left-panel');

    function triggerResize() {
        if (window.resizeRenderer) window.resizeRenderer();
        setTimeout(() => { if (window.resizeRenderer) window.resizeRenderer(); }, 280);
    }

    function syncPanelToScreen() {
        // So sánh với document width thực tế, không dùng window.innerWidth (bị ảnh hưởng bởi zoom)
        const w = document.documentElement.clientWidth;
        const small = w <= 1100;
        const icon  = document.getElementById('left-toggle-icon');
        if (small && !leftPanel.classList.contains('collapsed')) {
            leftPanel.classList.add('collapsed');
            if (icon) icon.className = 'fas fa-chevron-right';
            triggerResize();
        } else if (!small && leftPanel.classList.contains('collapsed')) {
            leftPanel.classList.remove('collapsed');
            if (icon) icon.className = 'fas fa-chevron-left';
            triggerResize();
        }
    }

    syncPanelToScreen();
    let _resizeTimer;
    window.addEventListener('resize', () => {
        clearTimeout(_resizeTimer);
        _resizeTimer = setTimeout(syncPanelToScreen, 100);
    });
    window.addEventListener('orientationchange', () => setTimeout(syncPanelToScreen, 200));

    window.toggleLeftPanel = function() {
        const willCollapse = !leftPanel.classList.contains('collapsed');
        leftPanel.classList.toggle('collapsed', willCollapse);
        const icon = document.getElementById('left-toggle-icon');
        if (icon) icon.className = willCollapse ? 'fas fa-chevron-right' : 'fas fa-chevron-left';
        triggerResize();
    };

    window.closeAllDrawers = function() {
        leftPanel.classList.add('collapsed');
        const icon = document.getElementById('left-toggle-icon');
        if (icon) icon.className = 'fas fa-chevron-right';
        if (window._closeFlyout) window._closeFlyout();
        triggerResize();
    };

})();
</script>

@section Scripts {
<script src="~/js/cargo-planner.js"></script>
<script>
// Cập nhật specs khi chọn container type trong tab Import
function onImportContainerChange() {
    const code = document.getElementById('import-container-type').value;
    const c    = CONTAINERS[code];
    const box  = document.getElementById('import-container-specs');
    if (!c || !box) return;

    const vol = (c.length * c.width * c.height / 1e6).toFixed(1);
    document.getElementById('ics-dim').textContent = `📐 ${c.length}×${c.width}×${c.height} cm`;
    document.getElementById('ics-vol').textContent = `📦 ${vol} m³`;
    document.getElementById('ics-wt').textContent  = `⚖️ ${c.maxWeight.toLocaleString()} kg`;
    box.style.display = '';

    // Tự điền tải trọng tối đa theo container
    document.getElementById('import-max-weight').value = c.maxWeight;
}

// ==================== PALLET TYPE CRUD ====================
window._palletTypes = [];

async function loadPalletTypes() {
    const res = await fetch('/api/pallet-types');
    window._palletTypes = await res.json();
}

function openPalletLibrary() {
    loadPalletTypes().then(renderPalletLibrary);
    document.getElementById('pallet-library-modal').classList.add('show');
}

function closePalletLibrary() {
    document.getElementById('pallet-library-modal').classList.remove('show');
}

function renderPalletLibrary() {
    const list = document.getElementById('pallet-library-list');
    list.innerHTML = '';
    if (!window._palletTypes.length) {
        list.innerHTML = '<div style="text-align:center;color:#718096;padding:32px 0;"><i class="fas fa-box-open" style="font-size:32px;margin-bottom:10px;display:block;"></i>Chưa có pallet nào</div>';
        return;
    }
    window._palletTypes.forEach(p => {
        const row = document.createElement('div');
        row.className = 'pallet-lib-row';
        row.innerHTML = `
            <div class="pallet-lib-left">
                <div class="pallet-lib-badge" style="background:${p.color}"></div>
                <div class="pallet-lib-info">
                    <div class="pallet-lib-name">${p.name}</div>
                    <div class="pallet-lib-dims">
                        <span><i class="fas fa-ruler-combined"></i> ${p.length}×${p.width}×${p.height} cm</span>
                        <span><i class="fas fa-weight-hanging"></i> ${p.weight} kg</span>
                    </div>
                </div>
            </div>
            <div class="pallet-lib-right">
                <div class="pallet-lib-qty-wrap">
                    <span class="pallet-lib-qty-label">SL</span>
                    <input type="number" class="pallet-lib-qty" value="1" min="1" max="9999" />
                </div>
                <button class="pallet-lib-btn-add" onclick="addPalletToImport(${p.id}, this)" title="Thêm vào danh sách">
                    <i class="fas fa-plus"></i>
                </button>
                <div class="pallet-lib-edit-del">
                    <button class="c-btn-edit" onclick="openEditPalletModal(${p.id})" title="Sửa"><i class="fas fa-edit"></i></button>
                    <button class="c-btn-del"  onclick="deletePalletType(${p.id})"    title="Xóa"><i class="fas fa-trash"></i></button>
                </div>
            </div>`;
        list.appendChild(row);
    });
}

function addPalletToImport(id, btn) {
    const p = window._palletTypes.find(x => x.id === id);
    if (!p) return;
    const qtyInput = btn.closest('.pallet-lib-row').querySelector('.pallet-lib-qty');
    const qty = Math.max(1, parseInt(qtyInput?.value) || 1);
    addImportRow(p.name, p.length, p.width, p.height, p.weight, qty, p.color);
    closePalletLibrary();
}

function openAddPalletModal() {
    document.getElementById('pt-modal-title').textContent = 'Thêm Pallet';
    document.getElementById('pt-id').value     = '';
    document.getElementById('pt-code').value   = '';
    document.getElementById('pt-name').value   = '';
    document.getElementById('pt-length').value = '';
    document.getElementById('pt-width').value  = '';
    document.getElementById('pt-height').value = '';
    document.getElementById('pt-weight').value = '';
    document.getElementById('pt-color').value  = '#F39C12';
    document.getElementById('pt-sort').value   = window._palletTypes.length + 1;
    document.getElementById('pt-code').disabled = false;
    document.getElementById('pallet-type-modal').classList.add('show');
}

function openEditPalletModal(id) {
    const p = window._palletTypes.find(x => x.id === id);
    if (!p) return;
    document.getElementById('pt-modal-title').textContent = 'Sửa Pallet';
    document.getElementById('pt-id').value     = p.id;
    document.getElementById('pt-code').value   = p.code;
    document.getElementById('pt-name').value   = p.name;
    document.getElementById('pt-length').value = p.length;
    document.getElementById('pt-width').value  = p.width;
    document.getElementById('pt-height').value = p.height;
    document.getElementById('pt-weight').value = p.weight;
    document.getElementById('pt-color').value  = p.color;
    document.getElementById('pt-sort').value   = p.sortOrder;
    document.getElementById('pt-code').disabled = true;
    document.getElementById('pallet-type-modal').classList.add('show');
}

function closePalletModal() {
    document.getElementById('pallet-type-modal').classList.remove('show');
}

async function savePalletModal() {
    const id = parseInt(document.getElementById('pt-id').value) || 0;
    const payload = {
        id,
        code:      document.getElementById('pt-code').value.trim(),
        name:      document.getElementById('pt-name').value.trim(),
        length:    parseFloat(document.getElementById('pt-length').value) || 0,
        width:     parseFloat(document.getElementById('pt-width').value)  || 0,
        height:    parseFloat(document.getElementById('pt-height').value) || 0,
        weight:    parseFloat(document.getElementById('pt-weight').value) || 0,
        color:     document.getElementById('pt-color').value,
        sortOrder: parseInt(document.getElementById('pt-sort').value) || 0,
        isActive:  true
    };
    if (!payload.code || !payload.name) { alert('Vui lòng nhập Code và Tên.'); return; }
    const method = id ? 'PUT' : 'POST';
    const url    = id ? `/api/pallet-types/${id}` : '/api/pallet-types';
    try {
        const res = await fetch(url, { method, headers: { 'Content-Type': 'application/json' }, body: JSON.stringify(payload) });
        if (!res.ok) { alert('Lỗi lưu: ' + res.status); return; }
        closePalletModal();
        await loadPalletTypes();
        renderPalletLibrary();
    } catch (e) { alert('Lỗi kết nối: ' + e.message); }
}

async function deletePalletType(id) {
    const p = window._palletTypes.find(x => x.id === id);
    if (!p || !confirm(`Xóa pallet "${p.name}"?`)) return;
    try {
        const res = await fetch(`/api/pallet-types/${id}`, { method: 'DELETE' });
        if (!res.ok && res.status !== 204) { alert('Lỗi xóa: ' + res.status); return; }
        await loadPalletTypes();
        renderPalletLibrary();
    } catch (e) { alert('Lỗi kết nối: ' + e.message); }
}

// Flyout cho sidebar thu nhỏ — chạy sau cargo-planner.js
(function() {
    const leftPanel     = document.getElementById('left-panel');
    const flyout        = document.getElementById('sidebar-flyout');
    const flyoutTitle   = document.getElementById('flyout-title');
    const flyoutContent = document.getElementById('flyout-content');

    const TAB_LABELS = {
        container: 'Container',
        import:    'Nhập pallet',
        cargo:     'Thêm hàng',
        list:      'Danh sách'
    };

    function closeFlyout() {
        flyout.classList.remove('show');
    }
    window._closeFlyout = closeFlyout;

    function openFlyout(tabId) {
        const src = document.getElementById('tab-' + tabId);
        if (!src) return;
        flyoutTitle.textContent = TAB_LABELS[tabId] || tabId;
        flyoutContent.innerHTML = src.innerHTML;
        flyout.classList.add('show');
    }

    // Click ngoài flyout thì đóng
    document.addEventListener('click', function(e) {
        if (!flyout.contains(e.target) && !leftPanel.contains(e.target)) {
            closeFlyout();
        }
    });

    // Override switchTab (defined as global fn in cargo-planner.js)
    const _origSwitchTab = window.switchTab;
    window.switchTab = function(tabId) {
        if (leftPanel.classList.contains('collapsed')) {
            openFlyout(tabId);
        } else {
            closeFlyout();
            if (_origSwitchTab) _origSwitchTab(tabId);
        }
    };
})();
</script>
}

