// ===== CAMERA: xác minh OCR + lưu ảnh container =====
let _camStream = null, _camMode = null, _camVerifyName = '', _camVerifyPass = null, _camArchive = null, _camVerifyCtx = null;
async function _startCam() {
    try {
        _camStream = await navigator.mediaDevices.getUserMedia({ video: { facingMode: 'environment' } });
        document.getElementById('camera-video').srcObject = _camStream;
    } catch (e) { alert('Không mở được camera: ' + e.message); closeCamera(); }
}
function closeCamera() {
    if (_camStream) { _camStream.getTracks().forEach(t => t.stop()); _camStream = null; }
    document.getElementById('camera-overlay').style.display = 'none';
    document.getElementById('camera-thumbs').innerHTML = '';
    document.getElementById('camera-status').textContent = '';
    // reset pane
    document.getElementById('verify-pane').style.display = 'none';
    document.getElementById('camera-video').style.display = '';
    document.getElementById('camera-actions').style.display = 'flex';
    _camMode = null; _verifySrc = null; _selRect = null;
}
function _grabCanvas() {
    const v = document.getElementById('camera-video'), cv = document.getElementById('camera-canvas');
    cv.width = v.videoWidth || 640; cv.height = v.videoHeight || 480;
    cv.getContext('2d').drawImage(v, 0, 0, cv.width, cv.height);
    return cv;
}
function _norm(s) { return (s || '').toUpperCase().replace(/[^A-Z0-9]/g, ''); }

// ===== Khoanh vùng + phân tích OCR (ngang/dọc/mờ) =====
let _verifySrc = null, _selRect = null, _selDrag = null;
function showVerifyPane() {
    document.getElementById('camera-video').style.display = 'none';
    document.getElementById('camera-actions').style.display = 'none';
    document.getElementById('verify-pane').style.display = 'flex';
    const cnv = document.getElementById('verify-canvas');
    cnv.width = _verifySrc.width; cnv.height = _verifySrc.height;
    _selRect = null;
    _drawVerify();
    document.getElementById('camera-status').textContent = 'Kéo khoanh vùng chữ rồi bấm "Phân tích".';
    _bindVerifySel(cnv);
}
function retakeVerify() {
    document.getElementById('verify-pane').style.display = 'none';
    document.getElementById('camera-video').style.display = '';
    document.getElementById('camera-actions').style.display = 'flex';
    document.getElementById('camera-status').textContent = 'Đưa camera tới chữ/số trên container rồi bấm Chụp';
}
function _drawVerify() {
    const cnv = document.getElementById('verify-canvas'), ctx = cnv.getContext('2d');
    ctx.drawImage(_verifySrc, 0, 0);
    if (_selRect) {
        ctx.strokeStyle = '#38a169'; ctx.lineWidth = Math.max(2, cnv.width / 200);
        ctx.strokeRect(_selRect.x, _selRect.y, _selRect.w, _selRect.h);
        ctx.fillStyle = 'rgba(56,161,105,0.15)'; ctx.fillRect(_selRect.x, _selRect.y, _selRect.w, _selRect.h);
    }
}
function _evtToCanvas(cnv, e) {
    const r = cnv.getBoundingClientRect();
    const p = e.touches ? e.touches[0] : e;
    return { x: (p.clientX - r.left) / r.width * cnv.width, y: (p.clientY - r.top) / r.height * cnv.height };
}
function _bindVerifySel(cnv) {
    if (cnv._bound) return; cnv._bound = true;
    const down = e => { e.preventDefault(); const p = _evtToCanvas(cnv, e); _selDrag = { x0: p.x, y0: p.y }; };
    const move = e => { if (!_selDrag) return; e.preventDefault(); const p = _evtToCanvas(cnv, e);
        _selRect = { x: Math.min(_selDrag.x0, p.x), y: Math.min(_selDrag.y0, p.y), w: Math.abs(p.x - _selDrag.x0), h: Math.abs(p.y - _selDrag.y0) }; _drawVerify(); };
    const up = () => { _selDrag = null; if (_selRect && (_selRect.w < 8 || _selRect.h < 8)) { _selRect = null; _drawVerify(); } };
    cnv.addEventListener('mousedown', down); cnv.addEventListener('mousemove', move); window.addEventListener('mouseup', up);
    cnv.addEventListener('touchstart', down, { passive: false }); cnv.addEventListener('touchmove', move, { passive: false }); window.addEventListener('touchend', up);
}
// Tiền xử lý: phóng to + xám + tăng tương phản (giúp ảnh mờ)
function _preprocess(src) {
    const scale = Math.min(3, Math.max(1, 1100 / Math.max(src.width, src.height)));
    const c = document.createElement('canvas'); c.width = src.width * scale; c.height = src.height * scale;
    const ctx = c.getContext('2d'); ctx.imageSmoothingEnabled = true; ctx.drawImage(src, 0, 0, c.width, c.height);
    const img = ctx.getImageData(0, 0, c.width, c.height), d = img.data; let sum = 0;
    for (let i = 0; i < d.length; i += 4) { const g = 0.299*d[i]+0.587*d[i+1]+0.114*d[i+2]; d[i]=d[i+1]=d[i+2]=g; sum += g; }
    const mean = sum / (d.length / 4), k = 1.7;
    for (let i = 0; i < d.length; i += 4) { let v = (d[i]-mean)*k+mean; v = v<0?0:v>255?255:v; d[i]=d[i+1]=d[i+2]=v; }
    ctx.putImageData(img, 0, 0); return c;
}
function _rotate90(src) {
    const c = document.createElement('canvas'); c.width = src.height; c.height = src.width;
    const ctx = c.getContext('2d'); ctx.translate(c.width/2, c.height/2); ctx.rotate(Math.PI/2);
    ctx.drawImage(src, -src.width/2, -src.height/2); return c;
}
function _cropSel() {
    if (!_selRect) return _verifySrc;
    const c = document.createElement('canvas'); c.width = Math.round(_selRect.w); c.height = Math.round(_selRect.h);
    c.getContext('2d').drawImage(_verifySrc, _selRect.x, _selRect.y, _selRect.w, _selRect.h, 0, 0, c.width, c.height);
    return c;
}
async function analyzeVerify() {
    const st = document.getElementById('camera-status');
    const errMsg = e => (e && (e.message || e.toString())) || 'không rõ';
    st.textContent = '⏳ Đang khởi tạo OCR...';
    let worker;
    try {
        worker = await Tesseract.createWorker('eng', 1, {
            workerPath: '/lib/tesseract/worker.min.js',
            corePath: '/lib/tesseract/',
            langPath: '/lib/tesseract/'
        });
    } catch (e) { st.textContent = 'Lỗi tải OCR: ' + errMsg(e); return; }
    try {
        st.textContent = '⏳ Đang phân tích (chữ ngang + dọc)...';
        const rec = async cv => { const r = await worker.recognize(cv); return (r && r.data && r.data.text) || ''; };
        const pre = _preprocess(_cropSel());
        let combined = await rec(pre);                                       // ngang
        combined += ' ' + await rec(_rotate90(pre));                         // dọc
        combined += ' ' + await rec(_rotate90(_rotate90(_rotate90(pre))));   // dọc ngược
        const got = _norm(combined), want = _norm(_camVerifyName);
        if (want && got.includes(want)) {
            st.textContent = '✅ Khớp! Đang lưu ảnh...';
            const dataUrl = _verifySrc.toDataURL('image/jpeg', 0.85);
            if (_camVerifyCtx) { try { await fetch('/Plans/UploadPhoto', { method: 'POST', headers: { 'Content-Type': 'application/json' }, body: JSON.stringify({ id: _camVerifyCtx.id, ci: _camVerifyCtx.ci, image: dataUrl }) }); } catch (e) {} }
            st.textContent = '✅ Khớp & đã lưu ảnh — vào mô phỏng...';
            const cb = _camVerifyPass; setTimeout(() => { closeCamera(); if (cb) cb(); }, 900);
        } else {
            st.textContent = '❌ KHÔNG đúng. Đọc được: "' + combined.trim().replace(/\s+/g, ' ').slice(0, 60) + '". Khoanh lại vùng chữ hoặc bấm Chụp lại.';
        }
    } catch (e) { st.textContent = 'Lỗi OCR: ' + errMsg(e); }
    finally { try { await worker.terminate(); } catch (e) {} }
}

function openCameraVerify(name, id, ci, onPass) {
    _camMode = 'verify'; _camVerifyName = name; _camVerifyPass = onPass; _camVerifyCtx = { id, ci };
    document.getElementById('camera-title').textContent = '📷 Chụp xác minh container: "' + name + '"';
    document.getElementById('camera-status').textContent = 'Đưa camera tới chữ/số trên container rồi bấm Chụp';
    document.getElementById('camera-done-btn').style.display = 'none';
    document.getElementById('camera-file-btn').style.display = 'none';
    document.getElementById('verify-pane').style.display = 'none';
    document.getElementById('camera-video').style.display = '';
    document.getElementById('camera-actions').style.display = 'flex';
    document.getElementById('camera-overlay').style.display = 'flex';
    _startCam();
}
function openCameraArchive(id, ci, onDone) {
    _camMode = 'archive'; _camArchive = { id, ci, onDone, count: 0 };
    document.getElementById('camera-title').textContent = '📷 Chụp / thêm ảnh lưu trữ container';
    document.getElementById('camera-status').textContent = 'Bấm Chụp hoặc "Ảnh có sẵn" để thêm ảnh, xong bấm Xong';
    document.getElementById('camera-done-btn').style.display = 'inline-flex';
    document.getElementById('camera-file-btn').style.display = 'inline-flex';
    document.getElementById('camera-overlay').style.display = 'flex';
    _startCam();
}

// Upload 1 ảnh (dataURL) vào container đang lưu trữ
async function _uploadArchivePhoto(dataUrl) {
    if (!_camArchive) return false;
    const res = await (await fetch('/Plans/UploadPhoto', { method: 'POST', headers: { 'Content-Type': 'application/json' }, body: JSON.stringify({ id: _camArchive.id, ci: _camArchive.ci, image: dataUrl }) })).json();
    if (res.ok) {
        _camArchive.count++;
        const t = document.createElement('img'); t.src = res.url;
        t.style.cssText = 'width:64px;height:48px;object-fit:cover;border-radius:5px;border:1px solid #444;';
        document.getElementById('camera-thumbs').appendChild(t);
        return true;
    }
    return false;
}

// Chọn ảnh CÓ SẴN từ máy/iPad → upload
function cameraPickFiles(files) {
    if (!files || !files.length || _camMode !== 'archive') return;
    const st = document.getElementById('camera-status');
    let i = 0;
    [...files].forEach(f => {
        const reader = new FileReader();
        reader.onload = async () => {
            st.textContent = '⏳ Đang tải ảnh lên...';
            const ok = await _uploadArchivePhoto(reader.result);
            i++;
            st.textContent = ok ? `✅ Đã lưu ${_camArchive.count} ảnh` : 'Tải ảnh thất bại';
        };
        reader.readAsDataURL(f);
    });
    document.getElementById('camera-file').value = '';
}
async function cameraCapture() {
    const cv = _grabCanvas(), st = document.getElementById('camera-status');
    if (_camMode === 'verify') {
        if (typeof Tesseract === 'undefined') {
            if (confirm('Không tải được OCR (cần mạng). Bỏ qua bước xác minh?')) { const cb = _camVerifyPass; closeCamera(); if (cb) cb(); }
            return;
        }
        // Lưu ảnh gốc, chuyển sang màn KHOANH VÙNG chữ
        _verifySrc = document.createElement('canvas');
        _verifySrc.width = cv.width; _verifySrc.height = cv.height;
        _verifySrc.getContext('2d').drawImage(cv, 0, 0);
        showVerifyPane();
        return;
    } else if (_camMode === 'archive') {
        const dataUrl = cv.toDataURL('image/jpeg', 0.8);
        st.textContent = '⏳ Đang lưu ảnh...';
        try {
            const ok = await _uploadArchivePhoto(dataUrl);
            st.textContent = ok ? '✅ Đã lưu ' + _camArchive.count + ' ảnh' : 'Lưu ảnh thất bại';
        } catch (e) { st.textContent = 'Lỗi lưu ảnh: ' + e.message; }
    }
}
function cameraDone() {
    if (_camMode === 'archive') {
        if (_camArchive.count === 0 && !confirm('Chưa chụp ảnh nào. Vẫn tiếp tục?')) return;
        const cb = _camArchive.onDone; closeCamera(); if (cb) cb();
    }
}

// Xác nhận làm container → CHỤP XÁC MINH OCR trước → đúng mới vào mô phỏng
let _execCtx = null;
function startContainer(id, idx, name) {
    openCameraVerify(name || ('Container ' + (idx + 1)), id, idx, () => _proceedContainer(id, idx));
}
function _proceedContainer(id, idx) {
    openSavedContainer(id, idx);
    _execCtx = { id, idx };
    try { autoRotate = true; } catch (e) {} // tự xoay xem demo
    showForkliftWatchBanner(true, 'Đang mô phỏng xếp container... hãy xem hết');
    document.getElementById('finish-container-btn').style.display = 'none';
    // tạo dây đai (néo) để hiển thị trong lúc mô phỏng
    setTimeout(() => { if (typeof addLashing === 'function') try { addLashing(); } catch(e){} }, 350);
    // xem xong mô phỏng → chuyển "đang thực hiện" + YÊU CẦU bấm xác nhận từng pallet
    window._onForkliftDone = async function() {
        try { autoRotate = false; } catch (e) {} // dừng xoay để bấm pallet
        const res = await (await fetch('/Plans/StartContainer', { method:'POST', headers:{'Content-Type':'application/x-www-form-urlencoded'}, body: new URLSearchParams({ id, idx }) })).json();
        if (!res.ok) { showForkliftWatchBanner(false); alert(res.msg || 'Không thể bắt đầu container này.'); return; }
        document.querySelectorAll(`.plan-children[data-pid="${id}"]`).forEach(c => renderPlanContainers(id, c));
        setupPalletConfirm(id, idx);
    };
    setTimeout(() => { if (typeof playForkliftSim === 'function') playForkliftSim(); }, 700);
}

// Vào lại container ĐANG THỰC HIỆN để tiếp tục xác nhận pallet (không cần xem lại mô phỏng)
function resumeContainer(id, idx) {
    openSavedContainer(id, idx);
    _execCtx = { id, idx };
    setTimeout(() => { if (typeof addLashing === 'function') try { addLashing(); } catch(e){} }, 350);
    setupPalletConfirm(id, idx);
}

// Thiết lập bước bấm xác nhận TỪNG pallet; đủ hết mới hiện nút "Đã xếp xong"
async function setupPalletConfirm(id, idx) {
    const b = document.getElementById('finish-container-btn');
    b.style.display = 'none';
    window._execPlan = { planId: id, containerIdx: idx }; // để toggleLoaded lưu DB
    showForkliftWatchBanner(true, '👉 Bấm vào TỪNG pallet để xác nhận "đã lên", đủ hết mới được hoàn thành');
    // Khôi phục các pallet ĐÃ lưu trước đó (chống rớt mạng / tải lại trang)
    try {
        const meta = await (await fetch('/Plans/Containers?id=' + id)).json();
        const loaded = (meta.items && meta.items[idx] && meta.items[idx].loadedPallets) || [];
        setTimeout(() => { if (typeof applyLoadedFromServer === 'function') applyLoadedFromServer(loaded); }, 500);
    } catch (e) {}
    window._onLoadedProgress = function(done, total, allDone) {
        const bn = document.getElementById('fk-watch-banner');
        if (bn && bn.querySelector('span')) bn.querySelector('span').textContent = allDone
            ? `✅ Đã lên đủ ${done}/${total} pallet — bấm "Đã xếp xong"`
            : `👉 Đã lên ${done}/${total} pallet — bấm tiếp các pallet còn lại`;
        const fb = document.getElementById('finish-container-btn');
        if (allDone) { fb.style.display = 'flex'; fb.onclick = () => finishContainer(id, idx); }
        else fb.style.display = 'none';
    };
}

// Bấm "Đã xếp xong" → CHỤP ẢNH LƯU TRỮ container → rồi mới đánh dấu xong
function finishContainer(id, idx) {
    openCameraArchive(id, idx, () => _doFinishContainer(id, idx));
}
async function _doFinishContainer(id, idx) {
    const fd = new URLSearchParams({ id, idx });
    const res = await (await fetch('/Plans/SetContainerDone', { method:'POST', headers:{'Content-Type':'application/x-www-form-urlencoded'}, body: fd })).json();
    if (!res.ok) { alert(res.msg || 'Không thể đánh dấu.'); return; }
    document.getElementById('finish-container-btn').style.display = 'none';
    showForkliftWatchBanner(false);
    window._onLoadedProgress = null;
    window._execPlan = null;
    _execCtx = null;
    alert('✅ Đã xác nhận xếp xong container này!');
    document.querySelectorAll(`.plan-children[data-pid="${id}"]`).forEach(c => renderPlanContainers(id, c));
}

function showForkliftWatchBanner(show, text) {
    let el = document.getElementById('fk-watch-banner');
    if (!el) {
        el = document.createElement('div');
        el.id = 'fk-watch-banner';
        el.style.cssText = 'position:absolute;top:110px;left:50%;transform:translateX(-50%);background:rgba(237,137,54,0.95);color:#1a1a1a;font-weight:700;padding:8px 14px;border-radius:20px;z-index:60;font-size:13px;display:flex;align-items:center;gap:10px;';
        document.querySelector('.viewer-container')?.appendChild(el);
    }
    el.innerHTML = `<span>${text || ''}</span>`;
    el.style.display = show ? 'flex' : 'none';
}
</script>
}

